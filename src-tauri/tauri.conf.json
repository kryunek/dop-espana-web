{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DOP España",
  "version": "0.1.0",
  "identifier": "com.dop.espana",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DOP España",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
